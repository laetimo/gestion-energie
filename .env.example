# Configuration du serveur
PORT=3000
NODE_ENV=production

# Module Linky - Port série
ENABLE_LINKY=true
LINKY_PORT=/dev/ttyUSB0     # Adaptez selon votre système (COM3 sur Windows, /dev/ttyUSB0 sur Linux)
LINKY_BAUD=2400             # Vitesse de transmission TIC

# Capteurs Bluetooth
ENABLE_BLUETOOTH=true
BLE_SCAN_INTERVAL=30000     # Fréquence de scan en ms (30s par défaut)
BLE_DEVICE_ADDRESS=         # Laisser vide pour scan tous les appareils

# Base de données
DB_PATH=./data/energy.db

# Mise à jour
UPDATE_INTERVAL=30000       # Intervalle de mise à jour en ms
